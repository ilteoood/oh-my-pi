{
	"type": "module",
	"name": "@oh-my-pi/omp-remote",
	"version": "13.12.4",
	"description": "Remote control web UI for oh-my-pi coding agent",
	"homepage": "https://github.com/can1357/oh-my-pi",
	"author": "Can Boluk",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/can1357/oh-my-pi.git",
		"directory": "packages/remote"
	},
	"bugs": {
		"url": "https://github.com/can1357/oh-my-pi/issues"
	},
	"keywords": [
		"remote-control",
		"web-ui",
		"coding-agent",
		"websocket"
	],
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"check": "tsgo -p tsconfig.json && tsgo -p tsconfig.client.json",
		"build:client": "vite build",
		"dev:client": "vite"
	},
	"dependencies": {
		"@heroui/react": "3.0.0-rc.1",
		"@heroui/styles": "3.0.0-rc.1",
		"@oh-my-pi/pi-agent-core": "workspace:*",
		"@oh-my-pi/pi-coding-agent": "workspace:*",
		"@oh-my-pi/pi-utils": "workspace:*",
		"@tailwindcss/vite": "4.2.1",
		"@vitejs/plugin-react": "6.0.1",
		"hono": "^4.12.8",
		"i18next": "25.8.18",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-i18next": "16.5.8",
		"react-icons": "5.6.0",
		"react-markdown": "10.1.0",
		"react-router": "7.13.1",
		"rehype-highlight": "7.0.2",
		"remark-gfm": "4.0.1",
		"vite": "8.0.0",
		"zustand": "5.0.12"
	},
	"devDependencies": {
		"@types/bun": "^1.3.10",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"tailwindcss": "4.2.1"
	},
	"engines": {
		"bun": ">=1.3.8"
	},
	"files": [
		"src",
		"dist",
		"README.md"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts"
		},
		"./client": {
			"types": "./src/client/index.tsx",
			"import": "./src/client/index.tsx"
		},
		"./client/*": {
			"types": "./src/client/*.ts",
			"import": "./src/client/*.ts"
		}
	}
}
