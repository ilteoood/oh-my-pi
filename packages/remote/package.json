{
  "type": "module",
  "name": "@oh-my-pi/omp-remote",
  "version": "13.12.4",
  "description": "Remote control web UI for oh-my-pi coding agent",
  "homepage": "https://github.com/can1357/oh-my-pi",
  "author": "Can Boluk",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/can1357/oh-my-pi.git",
    "directory": "packages/remote"
  },
  "bugs": {
    "url": "https://github.com/can1357/oh-my-pi/issues"
  },
  "keywords": [
    "remote-control",
    "web-ui",
    "coding-agent",
    "websocket"
  ],
  "main": "./src/server/index.ts",
  "types": "./src/server/index.ts",
  "scripts": {
    "check": "tsgo -p tsconfig.json && tsgo -p tsconfig.client.json",
    "build:client": "vite build",
    "dev:client": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "prepack": "bun run build:client"
  },
  "dependencies": {
    "@heroui/react": "3.0.0-rc.1",
    "@heroui/styles": "3.0.0-rc.1",
    "@oh-my-pi/pi-agent-core": "workspace:*",
    "@oh-my-pi/pi-coding-agent": "workspace:*",
    "@oh-my-pi/pi-natives": "workspace:*",
    "@oh-my-pi/pi-utils": "workspace:*",
    "@tailwindcss/vite": "4.2.1",
    "@vitejs/plugin-react": "6.0.1",
    "clsx": "2.1.1",
    "hono": "^4.12.8",
    "i18next": "25.8.18",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "16.5.8",
    "react-icons": "5.6.0",
    "react-markdown": "10.1.0",
    "rehype-highlight": "7.0.2",
    "remark-gfm": "4.0.1",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/bun": "^1.3.10",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "^4.1.0",
    "happy-dom": "20.8.4",
    "tailwindcss": "4.2.1",
    "vite": "8.0.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "bun": ">=1.3.8"
  },
  "files": [
    "src",
    "README.md",
    "CHANGELOG.md",
    "dist"
  ],
  "exports": {
    "./server": {
      "types": "./src/server/index.ts",
      "import": "./src/server/index.ts"
    },
    "./server/*": {
      "types": "./src/server/*.ts",
      "import": "./src/server/*.ts"
    }
  }
}